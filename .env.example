MONGO_URI=mongodb://localhost:27017/zenith
JWT_SECRET=change-me-in-production
PORT=4000

# S3-compatible object storage (MinIO, AWS S3, DigitalOcean Spaces, etc.)
# Leave S3_ENDPOINT empty to use AWS S3 (virtual-hosted style URLs)
# Set S3_ENDPOINT for custom/self-hosted S3 (MinIO, etc.) — uses path-style URLs
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=zenith-prizes
