# Docker Compose — Phase 3 (Microservices)
# Copy to .env and fill in values before running: docker compose up --build

JWT_SECRET=change-me-in-production

# S3-compatible object storage (used by admin-service for image uploads)
# Leave S3_ENDPOINT empty to use AWS S3 (virtual-hosted style URLs).
# For Cloudflare R2, S3_ENDPOINT is the S3 API endpoint, without the bucket path:
#   https://<account-id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL is the public bucket root for viewing images in the browser:
#   https://<custom-domain>, https://pub-<hash>.r2.dev, or http://localhost:9000/zenith-prizes
# Set MINIO=true when the public URL is a MinIO/path-style host and should include S3_BUCKET.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=zenith-prizes
S3_PUBLIC_URL=
MINIO=false
