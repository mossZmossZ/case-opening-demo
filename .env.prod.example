# Docker Compose Prod — Phase 3 (Microservices)
# Copy to .env.prod and fill in values before running:
#   docker compose -f docker-compose-prod.yml --env-file .env.prod up -d

# Your Docker Hub username
DOCKERHUB_USERNAME=your-dockerhub-username

# Image tag to pull (e.g. 1.0.0, 1.2, latest)
IMAGE_TAG=latest

# Strong secret — change this before deploying
JWT_SECRET=change-me-to-a-long-random-string

# S3-compatible object storage (used by admin-service)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=zenith-prizes
